{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "rootDir": "./src",
    "outDir": "./dist",

    "moduleResolution": "node",

    "esModuleInterop": true,
    "strict": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,
    "sourceMap": true,

    "types": ["node"],
    "lib": ["ES2020"]
  }
}